# Copy of the secrets that must be set in the Streamlit Cloud dashboard under
#   App settings -> Secrets
#
# Streamlit exposes every top-level key here as an environment variable, which is
# how src/config.py picks them up. No code change is needed to switch the app
# between a local LM Studio and a tunnelled one.
#
# This file is an EXAMPLE. Do not commit a real .streamlit/secrets.toml —
# .gitignore excludes it.

# The public Cloudflare Tunnel hostname in front of deploy/llm_proxy.py.
# Note the /v1 suffix: the OpenAI SDK appends /chat/completions to it.
LLM_BASE_URL = "https://your-tunnel-hostname.trycloudflare.com/v1"

LLM_MODEL = "google/gemma-4-e4b"

# MUST equal the PROXY_TOKEN that deploy/llm_proxy.py was started with.
# The OpenAI SDK sends this as `Authorization: Bearer <key>`, which is exactly
# what the proxy checks. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
LLM_API_KEY = "replace-with-a-real-random-token"
