# Copy of the secrets that must be set in the Streamlit Cloud dashboard under
#   App settings -> Secrets
#
# Streamlit exposes every top-level key here as an environment variable, which is
# how src/config.py picks them up. No code change is needed to point the app at a
# different model endpoint.
#
# This file is an EXAMPLE. Do not commit a real .streamlit/secrets.toml —
# .gitignore excludes it.

# Any OpenAI-compatible endpoint the deployed app can reach. A cloud-hosted
# frontend cannot see the localhost in .env, so a deployed instance needs a
# routable address here. Note the /v1 suffix: the OpenAI SDK appends
# /chat/completions to it.
LLM_BASE_URL = "https://your-model-endpoint.example/v1"

LLM_MODEL = "google/gemma-4-e4b"

# The OpenAI SDK sends this as `Authorization: Bearer <key>`, so whatever serves
# the endpoint must expect exactly this value. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
LLM_API_KEY = "replace-with-a-real-random-token"
