# LM Studio runs on this machine, so localhost.
# If you later serve it from another PC, put that PC's LAN IP here instead.
LLM_BASE_URL=http://localhost:1234/v1
LLM_MODEL=google/gemma-4-e4b
LLM_API_KEY=lm-studio

# Path to the Superstore CSV (see README for download link)
DATA_PATH=data/superstore.csv
